generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(cuid())

  username String @unique
  password String

  refresh String?

  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ProjectStatus {
  planning
  active
  paused
  completed
  archived
}

model Project {
  id String @id @default(cuid())

  title       String
  description String?

  status ProjectStatus @default(planning)
  stats  ProjectStats?

  userId String

  tasks    Task[]
  features Feature[]
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status, updatedAt(sort: Desc)])
}

model ProjectStats {
  id String @id @default(cuid())

  ftotal       Int @default(0)
  fplanned     Int @default(0)
  fin_progress Int @default(0)
  fin_review   Int @default(0)
  fcompleted   Int @default(0)
  fdeployed    Int @default(0)

  ttotal     Int @default(0)
  ttodo      Int @default(0)
  tcompleted Int @default(0)

  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

enum FeatureStatus {
  planned
  in_progress
  in_review
  completed
  deployed
}

enum FeaturePriority {
  low
  medium
  high
  urgent
}

model Feature {
  id String @id @default(cuid())

  title       String
  description String?

  status   FeatureStatus   @default(planned)
  priority FeaturePriority @default(medium)
  stats    FeatureStats?

  projectId String

  tasks   Task[]
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, status, priority(sort: Desc), updatedAt(sort: Desc)])
}

model FeatureStats {
  id String @id @default(cuid())

  ttotal     Int @default(0)
  ttodo      Int @default(0)
  tcompleted Int @default(0)

  featureId String  @unique
  feature   Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@index([featureId])
}

enum TaskStatus {
  todo
  completed
}

model Task {
  id String @id @default(uuid())

  title String

  status TaskStatus @default(todo)

  due DateTime?

  featureId String
  projectId String

  feature Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([featureId, status(sort: Asc), updatedAt(sort: Desc)])
}
